<Window x:Class="DSE.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DSE.Desktop"
        mc:Ignorable="d"
        Title="DSE Control Panel" Height="400" Width="560"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="DSE Control Panel "
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,5">
            <TextBlock Text="Service Name:" Width="150"/>
            <TextBlock x:Name="ServiceNameText"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,5">
            <TextBlock Text="Status:" Width="150"/>
            <TextBlock x:Name="StatusText"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,5">
            <TextBlock Text="Machine Name:" Width="150"/>
            <TextBlock x:Name="MachineNameText"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,5">
            <TextBlock Text="Worker Version:" Width="150"/>
            <TextBlock x:Name="VersionText"/>
        </StackPanel>

        <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,5">
            <TextBlock Text="Started At:" Width="150"/>
            <TextBlock x:Name="StartedAtText"/>
        </StackPanel>

        <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="0,5">
            <TextBlock Text="Last Heartbeat:" Width="150"/>
            <TextBlock x:Name="LastHeartbeatText"/>
        </StackPanel>

        <StackPanel Grid.Row="7" Orientation="Horizontal" Margin="0,5,0,20">
            <TextBlock Text="Uptime (seconds):" Width="150"/>
            <TextBlock x:Name="UptimeText"/>
        </StackPanel>

        <Button Grid.Row="8"
                Content="Refresh Status"
                Width="150"
                Height="35"
                HorizontalAlignment="Left"
                Margin="0,20,0,0"
                Click="RefreshButton_Click"/>
    </Grid>
</Window>